{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc --build ../../lib/db ../../lib/api-zod && tsc -p tsconfig.json --noEmit",
    "lint:org-scope": "node ./scripts/check-org-scope.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/express": "^2.1.9",
    "@google-cloud/storage": "^7.19.0",
    "@swc/helpers": "^0.5.21",
    "@types/qrcode": "^1.5.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "http-proxy-middleware": "^3.0.5",
    "nodemailer": "^8.0.6",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "vitest": "^2.1.9"
  }
}
